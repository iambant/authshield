{
  "name": "authshield-js",
  "version": "0.1.0",
  "description": "Embeddable Node.js middleware library to detect and mitigate authentication account attacks.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo": "tsx demo/express-app.ts",
    "test": "npx vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "attack:spray": "tsx demo/attacks/spray.ts",
    "attack:stuffing": "tsx demo/attacks/stuffing.ts",
    "attack:bruteforce": "tsx demo/attacks/brute-force.ts",
    "attack:token-hijack": "tsx demo/attacks/token-hijack.ts",
    "attack:phishing": "tsx demo/attacks/phishing-like.ts",
    "attack:burst": "tsx demo/attacks/rate-limit-burst.ts",
    "attack:captcha-bypass": "tsx demo/attacks/captcha-bypass.ts",
    "attack:token-replay": "tsx demo/attacks/token-replay.ts",
    "attack:impossible-travel": "tsx demo/attacks/impossible-travel.ts",
    "attack:account-enum": "tsx demo/attacks/account-enumeration.ts",
    "attack:session-fixation": "tsx demo/attacks/session-fixation.ts",
    "attack:distributed-bruteforce": "tsx demo/attacks/distributed-brute-force.ts",
    "attack:session-fanout": "tsx demo/attacks/session-fanout.ts",
    "attack:success-after-fail-burst": "tsx demo/attacks/success-after-fail-burst.ts",
    "attack:all": "tsx demo/attacks/run-all.ts"
  },
  "keywords": [
    "security",
    "authentication",
    "middleware",
    "redis",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
